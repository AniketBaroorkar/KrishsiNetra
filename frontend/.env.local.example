# Supabase --------------------------------------------------------------
# Project URL and anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only). Never expose this to the browser.
# Used by /api/* routes to read/write Supabase tables.
SUPABASE_SERVICE_ROLE_KEY=

# Sentinel Hub ----------------------------------------------------------
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_BASE_URL=https://services.sentinel-hub.com

# Optional Django/legacy backend used as a secondary fallback ------------
KRISHINETRA_BACKEND_URL=http://127.0.0.1:8000
